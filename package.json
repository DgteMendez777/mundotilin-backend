{
  "name": "mundotilin-backend",
  "version": "1.0.0",
  "description": "Backend API para Mundo Tilín",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "start:dev": "tsx watch src/server.ts",
    "build": "tsc",
    "migrate": "tsx src/database/runMigrations.ts",
    "seed": "tsx src/database/runSeeders.ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "mundotilin",
    "express",
    "typescript",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}