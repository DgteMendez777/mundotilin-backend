generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName      String        @map("first_name") @db.VarChar(100)
  lastName       String        @map("last_name") @db.VarChar(100)
  email          String        @unique @db.VarChar(255)
  ci             String?       @unique @db.VarChar(20)
  passwordHash   String        @map("password_hash")
  phone          String?       @db.VarChar(20)
  profileImage   String?       @map("profile_image")
  role           user_role
  createdAt      DateTime?     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime?     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt      DateTime?     @map("deleted_at") @db.Timestamp(6)
  clownEvents    Event[]       @relation("ClownEvents")
  customerEvents Event[]       @relation("CustomerEvents")
  testimonials   Testimonial[]
  payments       Payment[]

  @@map("users")
}

model test_users {
  id         Int       @id @default(autoincrement())
  nombre     String?   @db.VarChar(100)
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

enum user_role {
  CLOWN
  CLIENT
}

model Event {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clownId       String       @map("clown_id") @db.Uuid
  customerId    String       @map("customer_id") @db.Uuid
  serviceId     String       @map("service_id") @db.Uuid
  title         String       @db.VarChar(150)
  eventDate     DateTime     @map("event_date") @db.Date
  startTime     DateTime     @map("start_time") @db.Time(6)
  address       String
  googleMapsUrl String?      @map("google_maps_url")
  childrenCount Int?         @map("children_count")
  observations  String?
  status        event_status @default(PENDING)
  totalAmount   Decimal      @map("total_amount") @db.Decimal(10, 2)
  createdAt     DateTime?    @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime?    @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamp(6)
  clown         User         @relation("ClownEvents", fields: [clownId], references: [id])
  customer      User         @relation("CustomerEvents", fields: [customerId], references: [id])
  service       Service      @relation(fields: [serviceId], references: [id])
  payments      Payment[]

  @@map("events")
}

enum event_status {
  PENDING
  CONFIRMED
  FINISHED

  @@map("event_status")
}

model EventCategory {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @db.VarChar(100)
  description String?
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamp(6)
  services    Service[]

  @@map("event_categories")
}

model Service {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId  String?        @map("category_id") @db.Uuid
  name        String         @db.VarChar(100)
  description String?
  basePrice   Decimal        @map("base_price") @db.Decimal(10, 2)
  coverImage  String?        @map("cover_image")
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime?      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime?      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt   DateTime?      @map("deleted_at") @db.Timestamp(6)
  category    EventCategory? @relation(fields: [categoryId], references: [id])
  events      Event[]

  @@map("services")
}

enum media_type {
  IMAGE
  VIDEO

  @@map("media_type")
}

model GalleryMedia {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String     @db.VarChar(150)
  description String?
  url         String
  publicId    String?    @map("public_id")
  type        media_type @default(IMAGE)
  isFeatured  Boolean    @default(false) @map("is_featured")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime?  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime?  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt   DateTime?  @map("deleted_at") @db.Timestamp(6)

  @@map("gallery_media")
}

model Testimonial {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId String @map("client_id") @db.Uuid

  clientName String  @map("client_name") @db.VarChar(120)
  comment    String
  rating     Int     @default(5)
  eventType  String? @map("event_type") @db.VarChar(100)
  imageUrl   String? @map("image_url")

  isFeatured Boolean @default(false) @map("is_featured")
  isActive   Boolean @default(true) @map("is_active")

  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(6)

  client User @relation(fields: [clientId], references: [id])

  @@map("testimonials")
}

enum payment_method {
  QR

  @@map("payment_method")
}

enum payment_status {
  PENDING
  REVIEW
  PAID
  REJECTED

  @@map("payment_status")
}

model Payment {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId       String         @map("event_id") @db.Uuid
  clientId      String         @map("client_id") @db.Uuid
  amount        Decimal        @db.Decimal(10, 2)
  method        payment_method @default(QR)
  status        payment_status @default(PENDING)
  qrImageUrl    String?        @map("qr_image_url")
  proofImageUrl String?        @map("proof_image_url")
  notes         String?

  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(6)

  event  Event @relation(fields: [eventId], references: [id])
  client User  @relation(fields: [clientId], references: [id])

  @@map("payments")
}
