generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName      String    @map("first_name") @db.VarChar(100)
  lastName       String    @map("last_name") @db.VarChar(100)
  email          String    @unique @db.VarChar(255)
  passwordHash   String    @map("password_hash")
  phone          String?   @db.VarChar(20)
  profileImage   String?   @map("profile_image")
  role           user_role
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamp(6)
  clownEvents    Event[]   @relation("ClownEvents")
  customerEvents Event[]   @relation("CustomerEvents")

  @@map("users")
}

model test_users {
  id         Int       @id @default(autoincrement())
  nombre     String?   @db.VarChar(100)
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

enum user_role {
  CLOWN
  CLIENT
}

model Event {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clownId       String       @map("clown_id") @db.Uuid
  customerId    String       @map("customer_id") @db.Uuid
  serviceId     String       @map("service_id") @db.Uuid
  title         String       @db.VarChar(150)
  eventDate     DateTime     @map("event_date") @db.Date
  startTime     DateTime     @map("start_time") @db.Time(6)
  address       String
  googleMapsUrl String?      @map("google_maps_url")
  childrenCount Int?         @map("children_count")
  observations  String?
  status        event_status @default(PENDING)
  totalAmount   Decimal      @map("total_amount") @db.Decimal(10, 2)
  createdAt     DateTime?    @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime?    @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamp(6)
  clown         User         @relation("ClownEvents", fields: [clownId], references: [id])
  customer      User         @relation("CustomerEvents", fields: [customerId], references: [id])
  service       Service      @relation(fields: [serviceId], references: [id])

  @@map("events")
}

enum event_status {
  PENDING
  CONFIRMED
  FINISHED

  @@map("event_status")
}

model EventCategory {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @db.VarChar(100)
  description String?
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt   DateTime  @map("deleted_at") @db.Timestamp(6)
  services    Service[]

  @@map("event_categories")
}

model Service {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId    String?        @map("category_id") @db.Uuid
  name          String         @db.VarChar(100)
  description   String?
  basePrice     Decimal        @map("base_price") @db.Decimal(10, 2)
  coverImage    String?        @map("cover_image")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime?      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime?      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt     DateTime?      @map("deleted_at") @db.Timestamp(6)
  category      EventCategory? @relation(fields: [categoryId], references: [id])
  events        Event[]
  includedItems ServiceIncludedItem[]

  @@map("services")
}

model ServiceIncludedItem {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId       String        @map("service_id") @db.Uuid
  inventoryItemId String        @map("inventory_item_id") @db.Uuid
  quantity        Int
  createdAt       DateTime?     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime?     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamp(6)
  service         Service       @relation(fields: [serviceId], references: [id])
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@map("service_included_items")
}
